{
  "mcpServers": {
    "kis-api-search": {
      "command": "/Users/YOUR_USERNAME/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "/Users/YOUR_USERNAME/workspace/koreainvestment-mcp",
        "--python", "3.13",
        "python", "server.py"
      ],
      "env": {}
    },
    "kis-ria": {
      "command": "/Users/YOUR_USERNAME/.local/bin/uv",
      "args": ["run", "--directory", "/Users/YOUR_USERNAME/workspace/KIS_MCP_Server", "python", "server.py"],
      "env": {
        "KIS_APP_KEY": "${KIS_APP_KEY_RIA}",
        "KIS_APP_SECRET": "${KIS_APP_SECRET_RIA}",
        "KIS_CANO": "${KIS_CANO_RIA}",
        "KIS_ACCOUNT_TYPE": "REAL",
        "KIS_DB_MODE": "motherduck",
        "MOTHERDUCK_DATABASE": "kis_portfolio",
        "KIS_DATA_DIR": "var",
        "MOTHERDUCK_TOKEN": "${MOTHERDUCK_TOKEN}"
      }
    },
    "kis-isa": {
      "command": "/Users/YOUR_USERNAME/.local/bin/uv",
      "args": ["run", "--directory", "/Users/YOUR_USERNAME/workspace/KIS_MCP_Server", "python", "server.py"],
