      "env": {
        "KIS_APP_KEY": "${KIS_APP_KEY_IRP}",
        "KIS_APP_SECRET": "${KIS_APP_SECRET_IRP}",
        "KIS_CANO": "${KIS_CANO_IRP}",
        "KIS_ACNT_PRDT_CD": "29",
        "KIS_ACCOUNT_TYPE": "REAL",
        "KIS_DB_MODE": "motherduck",
        "MOTHERDUCK_DATABASE": "kis_portfolio",
        "KIS_DATA_DIR": "var",
        "MOTHERDUCK_TOKEN": "${MOTHERDUCK_TOKEN}"
